APP_HOST=0.0.0.0
APP_PORT=8080
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

YDB_ENDPOINT=
YDB_DATABASE=
YDB_AUTO_CREATE_SCHEMA=1
YDB_DRIVER_TIMEOUT_SECONDS=10
YDB_TABLE_PREFIX=specto

# YDB SDK can pick credentials from env automatically.
# For local token-based access you can set:
# YDB_TOKEN=
# USE_METADATA_CREDENTIALS=1
# SA_KEY_FILE=/path/to/authorized-key.json

FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
# Or inline JSON instead of a file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
